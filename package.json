{
  "name": "cyberpath-academy",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "postinstall": "npm run db:setup",
    "dev": "npm run dev --workspace server & npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "db:setup": "npm run db:setup --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "start": "npm run start --workspace server",
    "seed": "npm run seed --workspace server",
    "backup": "npm run backup --workspace server",
    "test": "npm run test --workspace server",
    "verify": "npm run build && npm test",
    "smoke": "npm run db:setup && npm run verify"
  }
}
